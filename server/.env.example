# =============================================================================
# Holdex Server — Environment Variables
# =============================================================================
# Copy this file to .env for local development.
# NEVER commit .env to version control.
# For production, set these as Render environment variables.
# =============================================================================

# Server
NODE_ENV=development
PORT=3001

# ---------------------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------------------
# LOCAL DEVELOPMENT — Use a local MongoDB instance:
MONGODB_URI=mongodb://127.0.0.1:27017/holdex
#
# PRODUCTION — Replace with your MongoDB Atlas URI:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/holdex?retryWrites=true&w=majority

# Telegram Bot Token (from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ---------------------------------------------------------------------------
# Telegram Webhook (REQUIRED for Stars payments in production)
# ---------------------------------------------------------------------------
# Must be HTTPS and publicly accessible. Leave empty for local dev.
# TELEGRAM_WEBHOOK_URL=https://yourdomain.com

# Webhook Secret Token (optional but RECOMMENDED for production)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TELEGRAM_WEBHOOK_SECRET=your_random_secret_token_here

# JWT Secret (min 32 characters)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_32_char_minimum_secret_key_here_change_this

# TwelveData API Key (real-time market data)
TWELVE_DATA_API_KEY=your_twelvedata_api_key_here

# Frontend URL (used for CORS)
FRONTEND_URL=http://localhost:3000

# Additional allowed CORS origins (comma-separated, optional)
# ALLOWED_ORIGINS=https://app.holdex.com
