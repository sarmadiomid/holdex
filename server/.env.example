# Server
NODE_ENV=development
PORT=3001

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/holdex?retryWrites=true&w=majority

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Webhook URL (must be HTTPS and publicly accessible)
# Example: https://yourdomain.com
TELEGRAM_WEBHOOK_URL=https://yourdomain.com

# Telegram Webhook Secret Token (optional but recommended for production)
# Generate a random string (e.g., openssl rand -hex 32)
# This validates that webhook requests actually come from Telegram
TELEGRAM_WEBHOOK_SECRET=your_random_secret_token_here

# JWT
JWT_SECRET=your_32_char_minimum_secret_key_here_change_this

# TwelveData
TWELVE_DATA_API_KEY=your_twelvedata_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
