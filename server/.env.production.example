# Server Environment Variables
# For production, add these in Render Dashboard → Environment Variables

# MongoDB Atlas or local
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/zollar

# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Webhook URL (your production server URL)
TELEGRAM_WEBHOOK_URL=https://your-server.onrender.com

# Telegram Webhook Secret Token (RECOMMENDED for production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This validates that webhook requests actually come from Telegram
TELEGRAM_WEBHOOK_SECRET=your_random_secret_token_here

# JWT secret (min 32 characters, generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_32_char_minimum_secret_here

# TwelveData API key
TWELVE_DATA_API_KEY=your_api_key_here

# Frontend URL for CORS (your Vercel deployment)
FRONTEND_URL=https://zollar.vercel.app

# Additional allowed origins (comma-separated, optional)
# ALLOWED_ORIGINS=https://app.zollar.com
